# =============================================================================
# Magus environment configuration
#
# Copy to `.env` and fill in. Notes:
#  - In dev/test the database connection comes from config/dev.exs and
#    config/test.exs, NOT from these variables. The vars here are used for
#    (a) provider API keys in any environment and (b) production / self-host
#    deployment (see config/runtime.exs).
#  - Run `mix magus.doctor` (dev) or, in a release,
#    `bin/magus eval "IO.puts(Magus.Config.Health.report())"` to see what is set.
# =============================================================================

# == Required in production / self-host =======================================
# (dev & test do not need these; they use config/{dev,test}.exs)

# Postgres connection. For docker-compose.selfhost.yml this points at the `db`
# service. Example: ecto://USER:PASS@HOST:5432/DATABASE
DATABASE_URL=ecto://postgres:postgres@db:5432/magus

# Phoenix secret for signing/encrypting cookies. Generate: `mix phx.gen.secret`
SECRET_KEY_BASE=

# Ash authentication token signing secret. Generate: `mix phx.gen.secret`
TOKEN_SIGNING_SECRET=

# ReAct agent checkpoint token secret. Generate: `mix phx.gen.secret`
REACT_TOKEN_SECRET=

# Cloak vault key encrypting integration secrets at rest (32 bytes, base64).
# Generate: `mix phx.gen.secret 32 | base64`
INTEGRATION_ENCRYPTION_KEY=

# Public hostname + URL used in emails and external links.
PHX_HOST=localhost
APP_URL=http://localhost:4000

# Start the web server in a release (set automatically by bin/server).
PHX_SERVER=true

# == LLM providers (at least one required to use the app) =====================
# OpenRouter is the primary gateway; most models route through it.
OPENROUTER_API_KEY=
# Optional direct providers:
OPENAI_API_KEY=
AIML_API_KEY=
# fal.ai (image / video generation)
FAL_KEY=

# == FalkorDB / Super Brain (optional graph features) =========================
# Only needed when SUPER_BRAIN_ENABLED=true. compose service name: falkordb
SUPER_BRAIN_ENABLED=false
FALKORDB_HOST=falkordb
FALKORDB_PORT=6379
FALKORDB_PASSWORD=
FALKORDB_POOL_SIZE=10

# == Web search & crawl (optional capabilities) ===============================
# Without these the web_search / crawl agent tools are gated off.
EXA_API_KEY=
EXA_SERVICE_KEY=
SPIDER_API_KEY=

# == Sandbox code execution (optional) ========================================
# Provider: daytona (default) or sprites. Without a key the sandbox tools are
# gated off (Magus.Sandbox.Provider.configured?/0).
SANDBOX_PROVIDER=daytona
DAYTONA_API_KEY=
DAYTONA_SANDBOX_IMAGE=
SPRITES_API_KEY=
SPRITES_BASE_URL=https://api.sprites.dev

# == File storage =============================================================
# Default (nothing set): local disk at priv/static/uploads. Zero-dependency and
# fine for single-node self-host, but mount a persistent volume there or files
# are lost on restart, and it does NOT work across multiple nodes.
#
# For production / multi-node use S3-compatible object storage (AWS S3, Tigris,
# or self-hosted MinIO): set AWS_BUCKET below and it is selected automatically.
# Force the choice with STORAGE_BACKEND=local or STORAGE_BACKEND=s3 (s3 without
# AWS_BUCKET fails fast at boot).
# STORAGE_BACKEND=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=
AWS_REGION=auto
AWS_S3_HOST=https://s3.amazonaws.com

# == Email delivery (optional) ================================================
# With POSTMARK_API_KEY set, mail is delivered via Postmark; otherwise mail is
# stored locally and NOT delivered (configure your own Swoosh adapter for SMTP).
POSTMARK_API_KEY=

# == OAuth integrations (optional) ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
# OneDrive (Microsoft Graph) knowledge source
# ONEDRIVE_CLIENT_ID=
# ONEDRIVE_CLIENT_SECRET=
# Dropbox knowledge source
# DROPBOX_APP_KEY=
# DROPBOX_APP_SECRET=

# == Commercial billing edition (cloud only; leave unset for OSS self-host) ===
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
