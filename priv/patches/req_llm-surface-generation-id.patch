@@ -1186,6 +1188,20 @@ defmodule ReqLLM.Provider.Defaults do
 
   def default_decode_stream_event(_, _model), do: []
 
+  # Capture the provider's generation id (e.g. OpenRouter "gen-...") onto a
+  # terminal metadata chunk so callers can reconcile usage/cost against the
+  # provider's authoritative record (GET /api/v1/generation) after the stream
+  # completes. Rides on every SSE chunk; we only attach it to terminal metas
+  # (finish_reason / usage) to avoid flooding the stream.
+  defp maybe_put_generation_id(meta, data) when is_map(data) do
+    case Map.get(data, "id") do
+      id when is_binary(id) and id != "" -> Map.put(meta, :id, id)
+      _ -> meta
+    end
+  end
+
+  defp maybe_put_generation_id(meta, _data), do: meta
+
   defp decode_openai_message(message) when is_map(message) do
     content_chunks = decode_openai_content(message)
     reasoning_chunks = decode_openai_reasoning(message)
