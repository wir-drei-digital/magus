+  @doc """
+  Await the metadata task and return the provider's generation id.
+
+  For OpenRouter this is the `gen-...` id used to query the generation endpoint
+  (`GET /api/v1/generation?id=...`) for authoritative usage and cost. Returns
+  `nil` when the provider did not supply one.
+
+  ## Timeout
+
+  Blocks until metadata collection completes, like `usage/1`.
+  """
+  @spec provider_id(t()) :: String.t() | nil
+  def provider_id(%__MODULE__{metadata_handle: handle}) do
+    metadata = MetadataHandle.await(handle)
+
+    case metadata do
+      %{id: id} when is_binary(id) and id != "" -> id
+      _ -> nil
+    end
+  end
+
